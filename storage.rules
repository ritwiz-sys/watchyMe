rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // User avatars — owner can write, authenticated users can read
    match /avatars/{userId}/{allPaths=**} {
      allow read:  if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId
                   && request.resource.size < 2 * 1024 * 1024   // 2 MB limit
                   && request.resource.contentType.matches('image/.*');
    }

    // Room media / thumbnails — authenticated users can read; server writes via Admin SDK
    match /rooms/{roomId}/{allPaths=**} {
      allow read:  if request.auth != null;
      allow write: if false;   // server-only via Admin SDK
    }

    // Deny everything else
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
